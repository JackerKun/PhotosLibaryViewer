{
  "name": "photos-library-viewer",
  "version": "1.0.0",
  "description": "Cross-platform Apple Photos Library Viewer",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && VITE_DEV_SERVER_URL=http://localhost:5173 NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:win": "vite build && electron-builder --win",
    "start": "node_modules/.bin/electron .",
    "start:sample": "node_modules/.bin/electron . \"../default.photoslibrary\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2",
    "electron": "^29.1.1",
    "electron-builder": "^24.13.3",
    "postcss": "^8.4.35",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.photoslibviewer.app",
    "productName": "Photos Library Viewer",
    "icon": "build/icon",
    "compression": "store",
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.photography",
      "icon": "build/icon.icns",
      "target": "dmg"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "linux": {
      "icon": "build/icon.png",
      "target": "AppImage"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "node_modules/**/*"
    ],
    "extraResources": []
  }
}
